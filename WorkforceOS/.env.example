# HRM System Environment Variables

# Django
DJANGO_SECRET_KEY=change-me-in-production-use-a-real-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://hrm_user:hrm_password@localhost:5432/hrm_db
DB_NAME=hrm_db
DB_USER=hrm_user
DB_PASSWORD=hrm_password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# Object Storage (S3/MinIO)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=hrm-documents
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_REGION_NAME=us-east-1

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ATS Integration
ATS_WEBHOOK_SECRET=change-me-ats-webhook-secret
ATS_BASE_URL=http://localhost:8000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email (additional)
DEFAULT_FROM_EMAIL=noreply@connecthr.com

# SQLite fallback (dev only — set to true to skip PostgreSQL requirement)
USE_SQLITE=false

# Sentry (production error tracking, optional)
# SENTRY_DSN=https://your-sentry-dsn@o123456.ingest.sentry.io/1234567
