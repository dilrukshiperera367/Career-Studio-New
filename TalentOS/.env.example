# ─── Django ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key-at-least-50-chars-long
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=ats_db
POSTGRES_USER=ats_user
POSTGRES_PASSWORD=ats_password_change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Redis / Celery ──────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── OpenSearch ───────────────────────────────────────────────────────────
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USE_SSL=False
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=

# ─── MinIO / S3 Storage ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=ats-resumes
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_REGION_NAME=us-east-1

# ─── Email (SMTP) ────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# ─── CORS ─────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Redis (cache) ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/2

# ─── Celery dev mode ──────────────────────────────────────────────────────
# Set to True to run tasks synchronously without a worker (dev only)
CELERY_TASK_ALWAYS_EAGER=True

# ─── HRM Integration ──────────────────────────────────────────────────────
HRM_WEBHOOK_SECRET=replace-with-a-random-secret
HRM_BASE_URL=http://localhost:8001

# ─── Resume Parsing ───────────────────────────────────────────────────────
SPACY_MODEL=en_core_web_sm

# ─── Sentry (production error tracking, optional) ─────────────────────────
# SENTRY_DSN=https://your-sentry-dsn@o123456.ingest.sentry.io/1234567
